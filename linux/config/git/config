[pull]
	rebase = false
[init]
    defaultBranch = main
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[core]
	pager = delta
	editor = nvim
[interactive]
	diffFilter = delta --color-only
[delta]
    navigate = true
    side-by-side = true
    hyperlinks = true
    hyperlinks-file-link-format = "vscode://file/{path}:{line}"
    syntax-theme = "Dracula"
    file-style = "#4da6ff"
    file-decoration-style = "#4da6ff ul"
    hunk-header-decoration-style = "#4da6ff box"
    hunk-header-file-style = "#4da6ff"
    hunk-header-line-number-style = "#4da6ff"
    minus-style = "syntax #990000"
    line-numbers-minus-style = "red"
    line-numbers-plus-style = "green"
    line-numbers-left-style = "#4da6ff"
    line-numbers-right-style = "#4da6ff"
    line-numbers-zero-style = "#8c8c8c"
[merge]
	conflictStyle = zdiff3
